using CUNQAComplex = std::vector<double>;
using CUNQADiagonalMatrix = std::vector<CUNQAComplex>;
using CUNQARow = std::vector<CUNQAComplex>;
using CUNQAMatrix = std::vector<CUNQARow>;
using CUNQAComplexVector = std::vector<std::complex<double>>;

struct CUNQAInstruction {
  std::string name;
  std::vector<int> qubits = {};
  std::vector<int> clbits = {};
  std::vector<double> params = {};
  std::vector<double> axis = {};
  std::vector<std::string> qpus = {};
  std::vector<CUNQAInstruction> instructions = {}; 
  std::vector<CUNQAMatrix> matrix = {}; 
  std::vector<CUNQADiagonalMatrix> diagonal = {}; 
  std::vector<int> l_clbits = {};
  std::vector<int> r_clbits = {};
  std::vector<unsigned int> block_size = {};
  std::vector<unsigned int> pauli_id_list = {};
  std::string paulistr{};
  int seed = 0;
  int condition = 1;
  int num_controls = 0;
};

struct StructuredQuantumTask {
    std::string id;
    int n_qubits;
    int n_clbits;
    std::vector<CUNQAInstruction> instructions;
};

