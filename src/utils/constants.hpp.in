inline std::vector<CUNQAInstruction> from_json_instructions_to_cunqainstructions(const std::vector<JSON>& json_instructions)
{
    std::vector<CUNQAInstruction> cunqa_instructions;
    
    for (auto& instruction : json_instructions) {
        std::string instruction_name = instruction.at("name").get<std::string>();
        CUNQAInstruction cunqa_instruction = {};
        auto instruction_type = INSTRUCTIONS_MAP.at(instruction_name);

        switch (instruction_type) {
        case MEASURE:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(),
                .clbits = instruction.at("clbits").get<std::vector<int>>()
            };
            break;
        }
        case ID:
        case X:
        case Y:
        case Z:
        case H:
        case S:
        case SDG:
        case T:
        case TDG:
        case SX:
        case SY:
        case SZ:
        case SXDG:
        case SYDG:
        case SZDG:
        case P0:
        case P1:
        case V:
        case VDG:
        case K:
        case HZ2:
        case ID2:
        case ECR:
        case SWAP:
        case ISWAP:
        case SQRTSWAP:
        case CX:
        case CY:
        case CZ:
        case CH:
        case CSX:
        case CSXDG:
        case CSY:
        case CSZ:
        case CS:
        case CSDG:
        case CT:
        case DCX:
        case CECR:
        case CSWAP:
        case CSQRTSWAP:
        case CCX:
        case CCY:
        case CCZ:
        case MCX:
        case MCY:
        case MCZ:
        case MCS:
        case MCT:
        case MCH:
        case MCSX:
        case MCSWAP:
        case MCSQRTSWAP:
        case MX:
        case CMX:
        case BARRIER:
        case RESET:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>()
            };
            break;
        }
        case FUSEDSWAP:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(),
                .block_size = instruction.at("block_size").get<std::vector<unsigned int>>()
            };
            break;
        }
        case RAXIS: 
        case CRAXIS:
        case MCRAXIS:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(),
                .params = instruction.at("qubits").get<std::vector<double>>(),
                .axis = instruction.at("axis").get<std::vector<double>>()
            };
            break;
        }
        case PAULISTR:
        case CPAULISTR:
        case MCPAULISTR:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(),
                .paulistr = instruction.at("paulistr").get<std::string>()
            };
            break;
        }
        case PAULIGADGET:
        case NONUNITARYPAULIGADGET: 
        case CPAULIGADGET:
        case MCPAULIGADGET: 
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(),
                .params = instruction.at("parmas").get<std::vector<double>>(),
                .paulistr = instruction.at("paulistr").get<std::string>()
            };
            break;
        }
        case MCMX:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(),
                .num_controls = instruction.at("num_controls").get<int>()
            };
            break;
        }
        case MCPHASEGADGET:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(),
                .params = instruction.at("parmas").get<std::vector<double>>(),
                .num_controls = instruction.at("num_controls").get<int>()
            };
            break;
        }
        case RX:
        case RY:
        case RZ:
        case GLOBALP:
        case P:
        case U1:
        case ROTINVX:
        case ROTINVY:
        case ROTINVZ:
        case ROTX:
        case ROTY:
        case ROTZ:
        case U2:
        case R:
        case U3:
        case U:
        case CRX:
        case CRY:
        case CRZ:
        case CP:
        case CU1:
        case RXX:
        case RYY:
        case RZZ:
        case RXY:
        case RZX:
        case CU2:
        case CR:
        case XXMYY:
        case XXPYY:
        case FS:
        case CU3:
        case CU:
        case MCRX:
        case MCRY:
        case MCRZ:
        case MCP:
        case MCU1:
        case MCU2:
        case MCR:
        case MCU3:
        case MCU:
        case PHASEGADGET:
        case CPHASEGADGET:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .params = instruction.at("params").get<std::vector<double>>()
            };
            break;
        }
        case MULTIPAULI:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .pauli_id_list = instruction.at("pauli_id_list").get<std::vector<unsigned int>>()
            };
            break;
        }
        case MULTIPAULIROTATION:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .params = instruction.at("params").get<std::vector<double>>(),
                .pauli_id_list = instruction.at("pauli_id_list").get<std::vector<unsigned int>>()
            };
            break;
        }
        case UNITARY:
        case SPARSEMATRIX:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .matrix = instruction.at("matrix").get<std::vector<CUNQAMatrix>>()
            };
            break;
        }
        case DIAGONAL:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .diagonal = instruction.at("matrix").get<std::vector<CUNQADiagonalMatrix>>()
            };
            break;
        }
        case AMPLITUDEDAMPINGNOISE:
        case BITFLIPNOISE:
        case DEPHASINGNOISE:
        case DEPOLARIZINGNOISE:
        case INDEPENDENTXZNOISE:
        case TWOQUBITDEPOLARIZINGNOISE:
        {
            int seed = instruction.contains("seed") ? instruction.at("seed").get<int>() : 0;
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .params = instruction.at("params").get<std::vector<double>>(),
                .seed = seed
            };
            break;
        }
        case RANDOMUNITARY:
        {
            int seed = instruction.contains("seed") ? instruction.at("seed").get<int>() : 0;
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .seed = seed
            };
            break;
        }
        case COPY:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .l_clbits = instruction.at("l_clbits").get<std::vector<int>>(),
                .r_clbits = instruction.at("r_clbits").get<std::vector<int>>()
            };
            break;
        }
        case SEND:
        case RECV:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .clbits = instruction.at("clbits").get<std::vector<int>>(), 
                .qpus = instruction.at("qpus").get<std::vector<std::string>>()
            };
            break;
        }
        case CIF:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .clbits = instruction.at("clbits").get<std::vector<int>>(), 
                .instructions = from_json_instructions_to_cunqainstructions(instruction.at("instructions").get<cunqa::JSON>()),
                .condition = instruction.at("condition").get<int>()
            };
            break;
        }
        case QSEND:
        case QRECV:
        case EXPOSE:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qubits = instruction.at("qubits").get<std::vector<int>>(), 
                .qpus = instruction.at("qpus").get<std::vector<std::string>>()
            };
            break;
        }
        case RCONTROL:
        {
            cunqa_instruction = {
                .name = instruction_name,
                .qpus = instruction.at("qpus").get<std::vector<std::string>>(),
                .instructions = from_json_instructions_to_cunqainstructions(instruction.at("instructions").get<cunqa::JSON>())
            };
            break;
        }
        default:
            std::cerr << "Instruction not suported!" << "\n";
        } // End switch

        cunqa_instructions.push_back(cunqa_instruction);
    }

    return cunqa_instructions;
}

} // End namespace constants
} //End namespace cunqa





